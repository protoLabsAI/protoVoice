# protoVoice local secrets + config.
#
# Copy to `.env` and fill in values. `.env` is gitignored. For deployed
# boxes, prefer injecting these via your secrets manager (Infisical,
# Vault, SOPS, k8s Secret + envFrom, etc.) — the app reads `os.environ`,
# doesn't care where the values came from.

# ─── Ports + paths ──────────────────────────────────────────────────
#PORT=7866
#HF_HOME=/mnt/models/huggingface
#CONFIG_DIR=config
#DELEGATES_YAML=config/delegates.yaml

# ─── Router LLM (in-pipeline) ───────────────────────────────────────
#START_VLLM=0
#LLM_URL=http://localhost:8000/v1
#LLM_SERVED_NAME=local
#LLM_API_KEY=
#LLM_MAX_TOKENS=150
#LLM_TEMPERATURE=0.7
#SYSTEM_PROMPT=

# ─── STT ────────────────────────────────────────────────────────────
#STT_BACKEND=local                     # local | openai
#WHISPER_MODEL=openai/whisper-large-v3-turbo
#STT_URL=https://api.openai.com/v1     # STT_BACKEND=openai
#STT_MODEL=whisper-1
#STT_API_KEY=

# ─── TTS ────────────────────────────────────────────────────────────
#TTS_BACKEND=fish                      # fish | kokoro | openai
#FISH_URL=http://fish-speech:8092
#FISH_REFERENCE_ID=
#KOKORO_VOICE=af_heart
#KOKORO_LANG=a
#TTS_OPENAI_URL=https://api.openai.com/v1
#TTS_OPENAI_MODEL=tts-1
#TTS_OPENAI_VOICE=alloy
#TTS_OPENAI_API_KEY=
#TTS_OPENAI_SAMPLE_RATE=24000

# ─── A2A inbound (other agents call us) ─────────────────────────────
#A2A_AUTH_TOKEN=                       # shared secret they send as X-API-Key
#AGENT_NAME=protovoice
#AGENT_VERSION=0.1.0
#A2A_MAX_TURNS=10

# ─── Delegates (referenced from config/delegates.yaml) ──────────────
# These are the env vars typical delegate entries point at.
# Add more as you extend config/delegates.yaml.
AVA_API_KEY=
#AVA_URL=http://ava:3008/a2a
#LITELLM_MASTER_KEY=                   # for a LiteLLM-fronted openai delegate

# ─── Audio handling ─────────────────────────────────────────────────
#ECHO_GUARD_MS=300
#HALF_DUPLEX=0
#NOISE_FILTER=off                      # off | rnnoise — needs .[rnnoise]
#SMART_TURN=off                        # off | local — needs .[smart-turn]

# ─── Filler verbosity + backchannels ────────────────────────────────
#VERBOSITY=brief                       # silent | brief | narrated | chatty
#BACKCHANNEL_FIRST_SECS=5.0
#BACKCHANNEL_INTERVAL_SECS=6.0

# ─── Memory ─────────────────────────────────────────────────────────
#MEMORY_MAX_MESSAGES=20
#MEMORY_SUMMARIZE=1

# ─── Tool tunables ──────────────────────────────────────────────────
#TZ=America/New_York
#SLOW_RESEARCH_SECS=20
#FAKE_RESEARCH_SECS=4
